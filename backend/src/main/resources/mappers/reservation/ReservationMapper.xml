<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.krh.backend.mappers.reservation.ReservationMapper">

    <insert id="insertReservation"
            useGeneratedKeys="true"
            keyProperty="id"
            parameterType="com.krh.backend.entities.reservation.Reservation">
        INSERT INTO `car`.`reservations` (
            `user_email`,
            `partner_id`,
            `partner_name`,
            `category`,
            `image_1`,
            `image_2`,
            `reserved_at`
        ) VALUES (
                     #{userEmail},
                     #{partnerId},
                     #{partnerName},
                     #{category},
                     #{image1},
                     #{image2},
                     #{reservedAt}
                 )
    </insert>

    <insert id="insertReservationItem"
            parameterType="com.krh.backend.entities.reservation.ReservationItem">
        INSERT INTO `car`.`reservation_items` (
            `reservation_id`, `item_name`
        ) VALUES (
                     #{reservationId}, #{itemName}
                 )
    </insert>

    <insert id="insertReservationItems" parameterType="java.util.List">
        INSERT INTO `car`.`reservation_items` (
        `reservation_id`, `item_name`
        ) VALUES
        <foreach collection="items" item="item" separator=","> (#{item.reservationId}, #{item.itemName})
        </foreach>
    </insert>

    <select id="selectLatestFinishedItem"
            resultType="com.krh.backend.entities.reservation.Reservation">
        SELECT r.`id`,
               r.`user_email`   AS `userEmail`,
               r.`reserved_at`  AS `reservedAt`,
               rv.`mileage`     AS `recordedMileage`
        FROM `car`.`reservations` r
                 JOIN `car`.`reservation_items` ri ON r.`id` = ri.`reservation_id`
                 LEFT JOIN `car`.`reviews` rv ON r.`id` = rv.`reservation_id`
        WHERE r.`user_email` = #{userEmail}
          AND ri.`item_name` = #{itemName}
          AND r.`status` = 'COMPLETED'
        ORDER BY r.`reserved_at` DESC
        LIMIT 1
    </select>

    <select id="selectReservationsByUserEmail"
            resultType="com.krh.backend.entities.reservation.Reservation">
        SELECT r.`id`,
               r.`user_email`   AS `userEmail`,
               r.`partner_id`   AS `partnerId`,
               r.`partner_name` AS `partnerName`,
               r.`category`,
               r.`image_1`      AS `image1`,
               r.`image_2`      AS `image2`,
               r.`reserved_at`  AS `reservedAt`,
               r.`status`,
               r.`created_at`   AS `createdAt`,
               rv.`id`          AS `reviewId`,
               rv.`mileage`     AS `recordedMileage`
        FROM `car`.`reservations` r
                 LEFT JOIN `car`.`reviews` rv ON r.`id` = rv.`reservation_id`
        WHERE r.`user_email` = #{userEmail}
        ORDER BY r.`reserved_at` DESC
    </select>

    <select id="selectItemsByReservationId"
            resultType="com.krh.backend.entities.reservation.ReservationItem">
        SELECT `id`,
               `reservation_id` AS `reservationId`,
               `item_name`      AS `itemName`
        FROM `car`.`reservation_items`
        WHERE `reservation_id` = #{reservationId}
    </select>

    <update id="updateReservation"
            parameterType="com.krh.backend.entities.reservation.Reservation">
        UPDATE `car`.`reservations`
        <set>
            <if test="reservedAt != null">`reserved_at` = #{reservedAt},</if>
<!--            <if test="description != null">`description` = #{description},</if>-->
            <if test="status != null">`status` = #{status}</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <delete id="deleteReservationById">
        DELETE
        FROM `car`.`reservations`
        WHERE `id` = #{id}
    </delete>

    <delete id="deleteItemsByReservationId">
        DELETE
        FROM `car`.`reservation_items`
        WHERE `reservation_id` = #{reservationId}
    </delete>

</mapper>